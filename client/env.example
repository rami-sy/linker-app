# ─── Client (Expo) ────────────────────────────────────────
# All public env vars MUST use the EXPO_PUBLIC_ prefix to be
# accessible at runtime in Expo / React Native bundles.

# Backend API & Socket server URL
EXPO_PUBLIC_API_URL=http://localhost:4000

# Google OAuth Web Client ID (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=294472116144-bgcqhr85smtcs7cck4roergenedchocd.apps.googleusercontent.com

# Facebook App ID (from Facebook Developers Console)
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
