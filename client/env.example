# ─── Client (Expo) ────────────────────────────────────────
# All public env vars MUST use the EXPO_PUBLIC_ prefix to be
# accessible at runtime in Expo / React Native bundles.

# Backend API & Socket server URL
EXPO_PUBLIC_API_URL=http://localhost:4000

# Client logging: debug | info | warn | error
EXPO_PUBLIC_LOG_LEVEL=warn

# Google Maps API key — restrict by HTTP referrer (web) and app bundle IDs (mobile)
# Rotate immediately if exposed; never commit real keys to git
# EXPO_PUBLIC_* values are bundled into web/native builds and must be treated as public.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Google OAuth Web Client ID (from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-google-web-client-id

# Facebook App ID (from Facebook Developers Console). Keep this placeholder to disable Facebook login locally.
EXPO_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
