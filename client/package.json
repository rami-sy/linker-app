  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-incall-manager",
          "react-native-webrtc",
          "expo-av",
          "expo-modules-core",
          "expo-image-loader"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "private": true
