{
  "name": "linker",
  "version": "1.1.2",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "tunnel": "expo start --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build-web": "cross-env NODE_ENV=production npm run remove-dist && npx expo export -p web -c && npm run move-dist",
    "postinstall": "node postinstall.js",
    "remove-dist": "rm -rf dist",
    "move-dist": "rm -rf ../server/dist && cp -r dist ../server/dist",
    "lint:doctor": "npx expo-doctor",
    "lint:code": "eslint \"src/contexts/socket.context.js\" \"src/utils/offlineQueue.js\" \"src/components/chat/chat-input.js\" \"app/(wrappers)/_layout.js\"",
    "lint": "npm run lint:doctor && npm run lint:code",
    "test:smoke": "node --test tests/smoke.test.js",
    "ci:web-smoke": "npx expo export --platform web --output-dir dist-ci --clear"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@gluestack-style/react": "^1.0.57",
