# Linker production environment (systemd EnvironmentFile)

NODE_ENV=production
PORT=4000

# Required
MONGO_URI=
JWT_SECRET=

# Recommended (used for queues / scaling / rate limits; app can run with fallback mode if Redis is down)
REDIS_URL=

# Reverse proxy / load balancer
TRUST_PROXY=true

# Comma-separated browser origins for REST + Socket.IO CORS
# Example: https://linker.land,https://www.linker.land
CORS_ORIGIN=

# mediasoup: MUST be your VPS public IPv4 (or a routable public IP)
MEDIASOUP_ANNOUNCED_IP=

# Ops endpoints protection in production: /ready and /metrics
# Send this via: header "x-ops-token: <OPS_TOKEN>"
OPS_TOKEN=

# Optional feature flags
CHAT_AI_ASSIST_ENABLED=false
SUSPICIOUS_LINK_WARNING_ENABLED=true
ADVANCED_CALL_MODERATION_ENABLED=true

# Optional TLS inside Node (NOT recommended when using Nginx in front)
TLS_ENABLED=false
TLS_KEY_PATH=./cert.key
TLS_CERT_PATH=./cert.crt

# Optional encryption (server-side payload encryption)
ENCRYPTION_ENABLED=false
ENCRYPTION_MASTER_KEY=

