# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# 1 = trust first proxy (required when behind nginx/load-balancer on DO)
TRUST_PROXY=1

# ─── Database ─────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/linker
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=294472116144-bgcqhr85smtcs7cck4roergenedchocd.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email (Google Workspace via Gmail SMTP) ──────────────
# Generate App Password: myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rami@linker.land
SMTP_PASS=your-16-char-app-password
SMTP_FROM=noreply@linker.land

# ─── SMS (Vonage) ─────────────────────────────────────────
VONAGE_API_KEY=your-vonage-api-key
VONAGE_API_SECRET=your-vonage-api-secret

# ─── MediaSoup ────────────────────────────────────────────
# Public IP of the server for WebRTC ICE candidates
MEDIASOUP_ANNOUNCED_IP=your-server-public-ip
# Worker count. Keep small in local development; omit in production to use CPU count.
MEDIASOUP_WORKERS=2
MEDIASOUP_DEBUG=false

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:19006

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CALL_RATE_LIMIT_MAX=10
CALL_RATE_LIMIT_WINDOW_MS=900000
UPLOAD_MAX_FILE_SIZE_MB=100

# ─── Internal / Dev ───────────────────────────────────────
# Token required for /api/ops/* maintenance endpoints
OPS_ENDPOINTS_TOKEN=change-this-in-production

# Magic OTP for local dev only — requires ALLOW_DEV_OTP=true (never enable in production)
ALLOW_DEV_OTP=false
DEV_MAGIC_OTP=123456

# Set to "true" + NODE_ENV=development to run DB seed on startup
SEED_DB=false
